&lt;td class="lntd">
&lt;pre tabindex="0" class="chroma">&lt;code class="language-text" data-lang="text">&lt;span class="line">&lt;span class="cl">你: 为以下函数生成测试用例
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">function divide(a, b) {
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> if (b === 0) throw new Error(&amp;#39;Cannot divide by zero&amp;#39;);
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> return a / b;
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">}
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">AI: 生成测试：
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">```javascript
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">describe(&amp;#39;divide&amp;#39;, () =&amp;gt; {
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> test(&amp;#39;正常除法&amp;#39;, () =&amp;gt; {
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> expect(divide(10, 2)).toBe(5);
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> });
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> 
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> test(&amp;#39;负数除法&amp;#39;, () =&amp;gt; {
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> expect(divide(-10, 2)).toBe(-5);
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> });
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> 
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> test(&amp;#39;除以零抛出错误&amp;#39;, () =&amp;gt; {
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> expect(() =&amp;gt; divide(10, 0)).toThrow(&amp;#39;Cannot divide by zero&amp;#39;);
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> });
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">});&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/td>&lt;/tr>&lt;/table>
&lt;/div>
