&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">## 边界值分析
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">```javascript
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">// 自动生成边界值测试
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">async function generateBoundaryTests(functionCode) {
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> const prompt = `
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">分析函数 ${functionCode}
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">生成边界值测试用例
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">`;
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> 
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl"> return await openclaw.generate(prompt);
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">}&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/td>&lt;/tr>&lt;/table>
