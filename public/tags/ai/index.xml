 class="absolute top-0 w-6 transition-opacity opacity-0 -start-6 not-prose group-hover:opacity-100 select-none">
 &lt;a class="text-primary-300 dark:text-neutral-700 !no-underline" href="#2-%e5%ae%89%e8%a3%85-openclaw" aria-label="">#&lt;/a>
 &lt;/span>
 
